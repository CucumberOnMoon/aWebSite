<scroll-view scroll-y class="page">
  <view class="card" wx:for="{{list}}" wx:key="id">
    <view class="hist-header">
      <text class="card-title">{{item.date}}</text>
      <text class="tag {{item.type}}">{{item.typeLabel}}</text>
    </view>
    <text class="text-muted">
      {{item.duration}} · {{item.sets}}组 · 容量{{item.volume}}kg
    </text>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>
  <view class="empty" wx:elif="{{!list.length}}">暂无训练记录</view>
</scroll-view>
