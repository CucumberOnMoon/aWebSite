.page {
  height: 100vh;
}

.hist-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hist-header .card-title { margin-bottom: 0; }

.tag.push { background: #1f6feb22; color: #58a6ff; border-color: #1f6feb44; }
.tag.pull { background: #3fb95022; color: #3fb950; border-color: #3fb95044; }
.tag.legs { background: #d2992222; color: #d29922; border-color: #d2992244; }

.card-push { background: #f851490d; }
.card-pull { background: #d299220d; }
.card-legs { background: #3fb9500d; }

.empty {
  text-align: center;
  padding: 60px 0;
  color: #8b949e;
  font-size: 14px;
}

/* 弹窗 */
.cal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); z-index: 100;
  display: flex; align-items: center; justify-content: center;
}
.cal-popup {
  background: #161b22; border: 1px solid #30363d; border-radius: 12px;
  padding: 16px; width: 85%; max-height: 70vh; overflow-y: auto;
}
.cal-popup-title { font-size: 14px; font-weight: 600; color: #e6edf3; margin-bottom: 12px; display: block; }
.cal-popup-ex { margin-bottom: 10px; }
.ex-title { font-size: 13px; font-weight: 600; color: #e6edf3; display: block; margin-bottom: 4px; }
.ex-sets { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4px; }
.set-detail { display: flex; align-items: center; background: #0d1117; border: 1px solid #30363d; border-radius: 6px; padding: 3px 8px; font-size: 11px; }
.set-num { color: #8b949e; font-size: 10px; margin-right: auto; }
.set-val { color: #3fb950; font-weight: 500; }
.text-muted { color: #8b949e; font-size: 11px; }
