.page { height: 100vh; background: #0d1117; padding-bottom: 20px; }
.hero-section { padding: 24px 16px 8px; }
.hero-title { font-size: 24px; font-weight: 700; color: #e6edf3; text-align: center; }

/* 用户选择器 */
.user-picker {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px; background: #161b22; border-bottom: 1px solid #30363d;
}
.user-label { font-size: 13px; color: #8b949e; }
.picker-box {
  display: flex; align-items: center; gap: 6px;
  background: #0d1117; border: 1px solid #30363d; border-radius: 8px; padding: 6px 12px;
}
.picker-text { font-size: 14px; color: #58a6ff; font-weight: 500; }
.picker-arrow { font-size: 10px; color: #8b949e; }

/* 弹窗 */
.modal-overlay { position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; }
.modal { background: #161b22; border: 1px solid #30363d; border-radius: 16px; padding: 24px; width: 300px; max-width: 85vw; }
.modal-title { font-size: 18px; font-weight: 600; color: #e6edf3; display: block; }
.modal-input { width: 100%; height: 40px; background: #0d1117; border: 1px solid #30363d; border-radius: 8px; padding: 0 12px; color: #c9d1d9; font-size: 14px; margin: 12px 0; box-sizing: border-box; }
.btn-modal { width: 100%; background: #238636; color: white; border: none; border-radius: 8px; padding: 10px; font-size: 14px; margin: 8px 0; text-align: center; }
.btn-modal.secondary { background: #1f6feb; }
.modal-cancel { display: block; text-align: center; color: #8b949e; font-size: 13px; padding: 8px; margin-top: 4px; }
.unbound-row { padding: 10px 0; border-bottom: 1px solid #21262d; color: #c9d1d9; font-size: 14px; }
.unbound-row:active { color: #58a6ff; }

.empty-state { text-align: center; padding: 80px 16px; font-size: 14px; color: #8b949e; }

.btn-start {
  display: block; width: 80%; margin: 20px auto 0;
  background: linear-gradient(135deg, #238636, #2ea043);
  color: white; border: none; border-radius: 12px;
  padding: 14px 20px; font-size: 16px; font-weight: 600; text-align: center;
}
.btn-start:active { opacity: 0.8; }

.btn-start-workout {
  display: block; width: 60%; margin: 12px auto 0;
  background: linear-gradient(135deg, #1f6feb, #58a6ff);
  color: white; border: none; border-radius: 10px;
  padding: 10px 16px; font-size: 14px; font-weight: 600; text-align: center;
}
.btn-start-workout:active { opacity: 0.8; }

/* ① 概览统计 */
.stat-row { display: flex; gap: 8px; padding: 12px 0 0; }
.stat-card { flex: 1; background: #161b22; border: 1px solid #30363d; border-radius: 10px; padding: 14px 8px; text-align: center; }
.stat-card .num { display: block; font-size: 24px; font-weight: 700; color: #58a6ff; }
.stat-card .label { display: block; font-size: 11px; color: #8b949e; margin-top: 2px; }

/* ── 通用卡片 ── */
.card { margin: 8px 16px; background: #161b22; border: 1px solid #30363d; border-radius: 12px; padding: 16px; }
.card-title { font-size: 15px; font-weight: 600; color: #e6edf3; display: block; margin-bottom: 8px; }
.card-sub { font-size: 11px; color: #8b949e; font-weight: 400; margin-left: 6px; }

/* ② PR 记录 */
.pr-item { display: flex; align-items: center; gap: 6px; padding: 7px 0; border-bottom: 1px solid #21262d; font-size: 12px; }
.pr-item:last-child { border-bottom: none; }
.pr-name { flex: 1; color: #c9d1d9; }
.pr-weight { color: #58a6ff; font-weight: 600; width: 40px; text-align: right; }
.pr-date { color: #8b949e; font-size: 10px; width: 44px; text-align: right; }

/* ③ 力量曲线 */
.sc-lift { margin-bottom: 14px; }
.sc-lift:last-child { margin-bottom: 0; }
.sc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
.sc-name { font-size: 13px; font-weight: 500; color: #c9d1d9; }
.sc-latest { font-size: 11px; color: #3fb950; }
.sc-chart { display: flex; align-items: flex-end; height: 80px; gap: 3px; padding: 0 4px; }
.sc-bar-wrap { flex: 1; display: flex; align-items: flex-end; justify-content: center; height: 100%; position: relative; }
.sc-bar { width: 100%; max-width: 20px; background: linear-gradient(to top, #1f6feb, #58a6ff); border-radius: 3px 3px 0 0; min-height: 4px; position: relative; }
.sc-bar-val { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); font-size: 9px; color: #58a6ff; white-space: nowrap; }
.sc-labels { display: flex; gap: 3px; margin-top: 2px; }
.sc-label { flex: 1; text-align: center; font-size: 8px; color: #8b949e; }

/* ④ 周训练量 */
.bar-chart-h { margin-top: 4px; }
.bar-row-h { display: flex; align-items: center; gap: 6px; padding: 4px 0; }
.bar-label-h { width: 44px; font-size: 10px; color: #8b949e; text-align: right; flex-shrink: 0; }
.bar-track-h { flex: 1; height: 14px; background: #0d1117; border-radius: 7px; overflow: hidden; }
.bar-fill-h { height: 100%; background: linear-gradient(90deg, #1f6feb, #58a6ff); border-radius: 7px; min-width: 2px; }
.bar-val-h { width: 36px; font-size: 10px; color: #c9d1d9; font-weight: 500; text-align: right; }

/* ⑤ 频率热力图 */
.cal-weekdays { display: flex; gap: 2px; margin-bottom: 4px; }
.cal-wd { flex: 1; text-align: center; font-size: 10px; color: #8b949e; }
.cal-grid { display: flex; flex-wrap: wrap; gap: 2px; }
.cal-cell { width: calc(100% / 7 - 2px); aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 11px; color: #8b949e; border-radius: 4px; background: #0d1117; }
.cal-empty { background: transparent; }
.cal-done { background: #1f6feb33; color: #58a6ff; font-weight: 600; }
.cal-today { border: 1px solid #58a6ff; }

/* ⑥ 推拉腿分布 */
.pie-legend { margin-top: 4px; }
.pie-item { display: flex; align-items: center; gap: 6px; padding: 5px 0; font-size: 11px; }
.pie-color { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
.pie-name { width: 32px; color: #8b949e; font-size: 10px; }
.pie-track { flex: 1; height: 14px; background: #0d1117; border-radius: 7px; overflow: hidden; }
.pie-fill { height: 100%; border-radius: 7px; min-width: 2px; }
.pie-val { width: 72px; color: #c9d1d9; font-weight: 500; text-align: right; font-size: 10px; }

/* ⑦ 上次训练 */
.last-workout { margin-top: 8px; }
.ex-group { margin-bottom: 8px; }
.ex-title { font-size: 13px; font-weight: 600; color: #e6edf3; display: block; margin-bottom: 4px; }
.ex-sets { display: flex; flex-wrap: wrap; gap: 4px; }
.set-detail { display: flex; align-items: center; gap: 4px; background: #0d1117; border: 1px solid #30363d; border-radius: 6px; padding: 3px 8px; font-size: 11px; }
.set-num { color: #8b949e; font-size: 10px; }
.set-val { color: #3fb950; font-weight: 500; }

/* ⑧ 亮点 */
.hl-item { padding: 6px 0; border-bottom: 1px solid #21262d; font-size: 12px; }
.hl-item:last-child { border-bottom: none; }
.hl-best { color: #f5c342; }
.hl-info { color: #58a6ff; }

/* 标签 */
.tag.push { background: #f8514922; color: #f85149; border-color: #f8514944; }
.tag.pull { background: #d2992222; color: #d29922; border-color: #d2992244; }
.tag.legs { background: #3fb95022; color: #3fb950; border-color: #3fb95044; }
.tag { display: inline-block; font-size: 10px; padding: 1px 5px; border-radius: 4px; border: 1px solid; line-height: 1.4; flex-shrink: 0; }
