.container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 60rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  text-align: center;
}

.hello {
  display: block;
  font-size: 64rpx;
  font-weight: 800;
  color: #4f46e5;
  margin-bottom: 16rpx;
}

.sub {
  display: block;
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 24rpx;
}

.time {
  display: block;
  font-size: 24rpx;
  color: #cbd5e1;
}
