<view class="container">
  <view class="logo-area">
    <text class="logo">💪</text>
    <text class="title">有没有你</text>
    <text class="subtitle">健身训练记录</text>
  </view>

  <view class="form-card">
    <input class="input" placeholder="用户名" model:value="{{username}}" bindinput="onUsernameInput" />
    <input class="input" password="{{true}}" placeholder="密码" model:value="{{password}}"  />
    
    <button class="login-btn" bindtap="onLogin" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '登录中...' : '登 录'}}
    </button>

    <text class="error" wx:if="{{error}}">{{error}}</text>
  </view>
</view>
