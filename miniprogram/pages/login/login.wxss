.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40px 32px;
}

.logo-area {
  text-align: center;
  margin-bottom: 40px;
}

.logo {
  font-size: 64px;
  display: block;
}

.title {
  font-size: 28px;
  font-weight: 700;
  color: #e6edf3;
  display: block;
  margin-top: 8px;
}

.subtitle {
  font-size: 14px;
  color: #8b949e;
  display: block;
  margin-top: 4px;
}

.form-card {
  width: 100%;
  max-width: 320px;
  background: #161b22;
  border: 1px solid #30363d;
  border-radius: 12px;
  padding: 24px;
}

.input {
  width: 100%;
  height: 44px;
  background: #0d1117;
  border: 1px solid #30363d;
  border-radius: 8px;
  padding: 0 12px;
  color: #c9d1d9;
  font-size: 14px;
  margin-bottom: 12px;
  box-sizing: border-box;
}

.input:focus {
  border-color: #1f6feb;
}

.login-btn {
  width: 100%;
  height: 44px;
  background: linear-gradient(135deg, #238636, #2ea043);
  color: white;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 500;
  margin-top: 8px;
  line-height: 44px;
}

.login-btn:active {
  opacity: 0.8;
}

.error {
  display: block;
  color: #f85149;
  font-size: 13px;
  text-align: center;
  margin-top: 12px;
}
