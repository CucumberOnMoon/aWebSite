<scroll-view scroll-y class="page">
  <!-- 计时器 -->
  <view class="timer-bar">
    <text class="timer">{{timer}}</text>
    <text class="text-muted">训练时长</text>
  </view>

  <!-- 动作列表 -->
  <view class="card" wx:for="{{exList}}" wx:key="id">
    <view class="ex-header" bindtap="onToggle" data-idx="{{index}}">
      <text class="card-title">{{ex.name}}</text>
      <text class="toggle">{{ex.open ? '▾' : '▸'}}</text>
    </view>

    <view wx:if="{{ex.open}}">
      <!-- 已记录组 -->
      <view class="set-row" wx:for="{{ex.sets}}" wx:key="sid" wx:for-item="s">
        <text class="set-num">第{{s.num}}组</text>
        <text class="text-success">{{s.weight_kg}}kg × {{s.reps}}</text>
        <text class="text-muted" wx:if="{{s.rir > 0}}">RIR {{s.rir}}</text>
      </view>

      <!-- 输入新组 -->
      <view class="add-set" wx:if="{{!ex.done}}">
        <view class="input-row">
          <view class="input-group">
            <text class="input-label">重量 kg</text>
            <input class="num-input" type="digit" 
                   value="{{ex.inWeight}}" 
                   bindinput="onIn" data-idx="{{index}}" data-field="inWeight" />
          </view>
          <view class="input-group">
            <text class="input-label">次数</text>
            <input class="num-input" type="number" 
                   value="{{ex.inReps}}" 
                   bindinput="onIn" data-idx="{{index}}" data-field="inReps" />
          </view>
          <view class="input-group">
            <text class="input-label">RIR</text>
            <input class="num-input" type="number" 
                   value="{{ex.inRir}}" 
                   bindinput="onIn" data-idx="{{index}}" data-field="inRir" />
          </view>
        </view>
        <button class="btn-add" bindtap="onAddSet" data-idx="{{index}}">+ 记录一组</button>
      </view>
    </view>
  </view>

  <!-- 完成 -->
  <view class="btn-area">
    <button class="btn-finish" bindtap="onFinish">✅ 完成训练</button>
  </view>

  <view class="loading" wx:if="{{loading}}">加载中...</view>
</scroll-view>
